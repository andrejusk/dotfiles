{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      { "type": "command", "bash": "$HOME/.tmux/copilot-state.sh working" }
    ],
    "preToolUse": [
      { "type": "command", "matcher": "ask_user", "bash": "$HOME/.tmux/copilot-state.sh question" }
    ],
    "postToolUse": [
      { "type": "command", "matcher": "ask_user", "bash": "$HOME/.tmux/copilot-state.sh working" }
    ],
    "agentStop": [
      { "type": "command", "bash": "$HOME/.tmux/copilot-state.sh waiting" }
    ],
    "errorOccurred": [
      { "type": "command", "bash": "$HOME/.tmux/copilot-state.sh error" }
    ],
    "sessionEnd": [
      { "type": "command", "bash": "$HOME/.tmux/copilot-state.sh clear" }
    ]
  }
}
