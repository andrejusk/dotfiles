{
  "editor.rulers": [80, 120],
  "editor.lineNumbers": "relative",
  "editor.fontFamily": "FiraCode Nerd Font, FiraCode NF, Fira Code, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.foldingImportsByDefault": false,
  "editor.inlineSuggest.enabled": true,
  "editor.accessibilitySupport": "off",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.formatOnType": false,

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  "workbench.startupEditor": "none",
  "workbench.editor.restoreViewState": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "GitHub Light Colorblind (Beta)",
  "workbench.activityBar.location": "top",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.remoteIndicator.showExtensionRecommendations": false,
  "material-icon-theme.folders.theme": "specific",

  "window.titleBarStyle": "custom",
  "window.customTitleBarVisibility": "auto",

  "terminal.integrated.fontFamily": "FiraCode Nerd Font, FiraCode NF, Fira Code, Consolas, 'Courier New', monospace",
  "terminal.integrated.fontSize": 11,
  "debug.console.fontSize": 11,
  "debug.javascript.autoAttachFilter": "onlyWithFlag",

  "diffEditor.ignoreTrimWhitespace": false,

  "git.confirmSync": false,
  "git.enableSmartCommit": true,

  "typescript.updateImportsOnFileMove.enabled": "always",

  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "jupyter.askForKernelRestart": false,

  "[dockerfile]": { "editor.defaultFormatter": "ms-azuretools.vscode-docker" },
  "[json]": { "editor.defaultFormatter": "vscode.json-language-features" },
  "[jsonc]": { "editor.defaultFormatter": "vscode.json-language-features" },
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[scss]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": { "editor.defaultFormatter": "yzhang.markdown-all-in-one" },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[shellscript]": { "editor.defaultFormatter": "foxundermoon.shell-format" },
  "[python]": { "editor.formatOnType": true },
  "[go]": {
    "editor.codeActionsOnSave": { "source.organizeImports": "explicit" }
  },
  "[go.mod]": {
    "editor.codeActionsOnSave": { "source.organizeImports": "explicit" }
  },

  "gitlens.advanced.messages": {
    "suppressGitMissingWarning": true
  },
  "gitlens.menus": {
    "editorGroup": { "blame": true, "compare": true },
    "explorer": { "clipboard": true, "compare": true, "history": true, "remote": true },
    "scm": { "authors": true },
    "scmGroupInline": { "stash": true },
    "scmGroup": { "compare": true, "openClose": true, "stash": true },
    "scmItem": { "clipboard": true, "compare": true, "history": true, "remote": false, "stash": true }
  },

  "vim.easymotion": true,
  "vim.useSystemClipboard": true,
  "vim.handleKeys": { "<C-o>": false },
  "vim.normalModeKeyBindingsNonRecursive": [
    { "before": ["<space>"], "commands": ["vspacecode.space"] },
    { "before": [","], "commands": ["vspacecode.space", { "command": "whichkey.triggerKey", "args": "m" }] }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    { "before": ["<space>"], "commands": ["vspacecode.space"] },
    { "before": [","], "commands": ["vspacecode.space", { "command": "whichkey.triggerKey", "args": "m" }] },
    { "before": [">"], "commands": ["editor.action.indentLines"] },
    { "before": ["<"], "commands": ["editor.action.outdentLines"] }
  ],

  "todo-tree.general.tags": ["BUG", "HACK", "FIXME", "TODO", "XXX", "[ ]", "[x]"],
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^\\s*(-|\\d+.))\\s*($TAGS)",
  "todo-tree.highlights.customHighlight": {
    "BUG": { "background": "#F00", "foreground": "#FFF", "icon": "bug" },
    "HACK": { "icon": "tools" },
    "TODO": { "background": "#FF0", "foreground": "#000" },
    "FIXME": { "background": "#FF0", "foreground": "#000", "icon": "flame" },
    "XXX": { "icon": "x" },
    "[ ]": { "icon": "issue-draft" },
    "[x]": { "icon": "issue-closed" }
  },

  "peacock.favoriteColors": [
    { "name": "Angular Red", "value": "#dd0531" },
    { "name": "Azure Blue", "value": "#007fff" },
    { "name": "JavaScript Yellow", "value": "#f9e64f" },
    { "name": "Mandalorian Blue", "value": "#1857a4" },
    { "name": "Node Green", "value": "#215732" },
    { "name": "React Blue", "value": "#61dafb" },
    { "name": "Something Different", "value": "#832561" },
    { "name": "Svelte Orange", "value": "#ff3d00" },
    { "name": "Vue Green", "value": "#42b883" }
  ],

  "terraform.languageServer.ignoreSingleFileWarning": true,
  "docker.extension.enableComposeLanguageServer": false,
  "remoteHub.commitDirectlyWarning": "off",
  "remote.autoForwardPortsSource": "hybrid",

  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.selectedCompletionModel": "gpt-4o-copilot",
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "chat.agent.maxRequests": 9001,
  "chat.permissions.default": "autopilot",

  "redhat.telemetry.enabled": false,
  "telemetry.telemetryLevel": "off",
  "update.mode": "none",
  "update.showReleaseNotes": false,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "extensions.ignoreRecommendations": true,
  "yaml.extension.recommendations": false
}
