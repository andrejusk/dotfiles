# Ghostty — managed by github.com/andrejusk/dotfiles via GNU Stow.
#
# Follow the macOS system appearance, mirroring how DOTS_THEME is resolved for
# the rest of the stack (shell, tmux, bat, fzf, glow). Both palettes derive
# from the repo's accessibility-tuned colours (see AGENTS.md "Colours"). The
# referenced themes live alongside this file in ./themes/.
theme = light:dots-light,dark:dots-dark

# Keep the window chrome (titlebar) in step with the active palette.
window-theme = auto

# Keep minimum-contrast at 1 (disabled). The zsh prompt (home/.zsh/prompt.zsh)
# draws its path/branch "pills" with padding characters coloured the SAME as
# their background (fg == bg) so they render as invisible block padding. Any
# value > 1 forces those zero-contrast cells to become legible, exposing the
# literal `#` / `(` / `)` padding. iTerm2 has no such feature, hence it looked
# fine there. Leave this at 1 unless the prompt stops using the pill technique.
minimum-contrast = 1

# Updates are owned by Homebrew, not Ghostty's built-in Sparkle updater.
# `off` stops the periodic check and every prompt it raises -- including
# Sparkle's first-launch "check for updates automatically?" dialog -- so the
# choice is declarative on every machine rather than a per-machine GUI click.
# The cask is `auto_updates true`, so brew defers to the app's self-updater;
# upgrade explicitly with:  brew upgrade --cask --greedy ghostty
auto-update = off

# --- Window & rendering polish ---
# Subtle translucency with blur behind the default background. Cells with an
# explicit background (e.g. the prompt pills) stay opaque because
# background-opacity-cells defaults to false.
background-opacity = 0.96
background-blur = true

# Reclaim the titlebar for a full-bleed window. tmux already provides tabs and a
# status line, so the native title bar / traffic-light buttons aren't needed
# (use Cmd+W / Cmd+M / Cmd+Q, or set this back to `transparent` to restore them).
macos-titlebar-style = hidden

# Breathing room around the grid, balanced so opposite edges match.
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true

# Hide the mouse pointer while typing.
mouse-hide-while-typing = true

# --- Typography ---
# A little extra line spacing for readability, plus slightly thicker glyphs.
adjust-cell-height = 8%
font-thicken = true

# --- Shell integration ---
# Add SSH support to the auto-detected zsh integration: ssh-terminfo installs the
# xterm-ghostty terminfo on remote hosts and ssh-env propagates TERM, so colours,
# keys, `clear` and tmux render correctly over SSH instead of "unknown terminal
# type". (cursor/title/path are the existing on-by-default features, kept.)
shell-integration-features = cursor,title,path,ssh-env,ssh-terminfo

# --- Keybinds ---
# Quake-style global dropdown terminal. The `global:` bind needs Ghostty granted
# Accessibility permission (System Settings > Privacy & Security > Accessibility).
keybind = global:cmd+grave_accent=toggle_quick_terminal
