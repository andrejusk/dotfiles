# ide
.vscode

# macOS metadata
.DS_Store
**/.DS_Store

# install artefacts
tmp
temp
**/logs
**/*.deb
.playwright-mcp/

# ssh env
**/id_*
**/known_hosts*
**/config.d

# setup files
**/autoload
**/pypoetry

# machine-local MCP overlays / generated configs
home/.copilot/mcp-config.json
home/.copilot/mcp-config.local.json

# XDG runtime state (safety net: 23-stow.sh mkdir's ~/.local/bin so stow links
# only bin/ scripts and never folds ~/.local into the repo — but if a fold ever
# recurs, keep mise/gh/zsh runtime writes out of version control)
home/.local/share
home/.local/state

# vim plugins (installed via install script)
home/.vim/pack

# tmux plugins (installed via install script)
home/.tmux/plugins

# compiled binaries
home/.tmux/donut

*.zwc

# python bytecode (e.g. from linting bin/ python helpers)
__pycache__/
*.pyc
